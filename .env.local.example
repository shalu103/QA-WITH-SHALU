# Supabase — copy from your project's API settings
# https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role key — used only in server-side code, NEVER expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Your admin email (the only email allowed to log in as admin)
ADMIN_EMAIL=shalu@example.com

# Site URL — used for canonical URLs and Open Graph
NEXT_PUBLIC_SITE_URL=https://qawithshalu.com

# Analytics — add these when ready (leave blank until then)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_CLARITY_PROJECT_ID=
